{
  admin off
  auto_https off
}

:{$PORT:10000} {
  encode zstd gzip

  @health path /health /livez
  respond @health "ok" 200

  @backend path /api/* /ws/* /listing_photos/* /stock-images/* /stock_photos/* /streetview_images/*
  handle @backend {
    reverse_proxy {$API_UPSTREAM:https://api.thepropertydomain.com.au}
  }

  handle {
    root * /srv
    try_files {path} {path}/ /index.html
    file_server
  }
}
